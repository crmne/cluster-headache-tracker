<section class="py-16 bg-base-200 sm:py-20">
  <div class="px-4 mx-auto max-w-4xl sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12">
      <div class="text-center">
        <h3 class="text-2xl font-bold mb-4">It's open source.</h3>
        <p class="mb-6 opacity-70">
          This isn't a startup. It's a tool built by a sufferer, for sufferers.
          The code is public so it can't disappear when some company gets
          acquired.
        </p>
        <a href="https://github.com/crmne/cluster_headache_tracker" target="_blank" rel="noopener noreferrer"
           class="btn btn-outline">
          <%= icon "github", class: "w-5 h-5", fill: "currentColor" %>
          See the Code
        </a>
      </div>
      <div class="text-center">
        <h3 class="text-2xl font-bold mb-4">Help keep it running.</h3>
        <p class="mb-6 opacity-70">
          I pay for servers out of pocket. If this helped you, consider
          chipping in for coffee. No pressure though - the tool stays free
          either way.
        </p>
        <a href="https://github.com/sponsors/crmne" target="_blank" rel="noopener noreferrer"
           class="btn btn-primary">
          Sponsor
          <%= heroicon "heart", variant: "mini", class: "w-5 h-5" %>
        </a>
      </div>
    </div>
  </div>
</section>
