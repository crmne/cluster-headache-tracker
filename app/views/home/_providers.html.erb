<section class="py-16 bg-base-200 sm:py-20">
  <div class="px-4 mx-auto max-w-4xl sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold sm:text-4xl xl:text-5xl">
        For healthcare providers.
      </h2>
    </div>

    <div class="prose prose-lg mx-auto">
      <p>
        Your patients struggle to explain their pain. We help them show you.
        They get timestamped logs, KIP scale ratings, duration tracking,
        treatment notes. You get clean data, not vague recollections.
      </p>

      <p>
        Patients generate a secure link that gives you <strong>beautiful,
        professional reports</strong>. One click and you see everything:
        comprehensive tables with every logged attack, visual charts showing
        patterns and cycles, medication effectiveness graphs. No app needed.
        Just click and view their complete history presented exactly how you
        need it.
      </p>
    </div>

    <div class="text-center mt-10">
      <%= link_to neurologist_path, class: "btn btn-primary" do %>
        More Info for Providers
        <%= heroicon "arrow-right", variant: "mini", class: "w-5 h-5" %>
      <% end %>
    </div>
  </div>
</section>
