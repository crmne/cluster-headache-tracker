#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
cd "$repo_root"

git config core.hooksPath .githooks

cat <<'MSG'
Configured git hooks to use .githooks/pre-push (runs bundle exec bin/ci).
If you previously installed Overcommit hooks, run `overcommit --uninstall`
to remove them. To revert to default hooks, run `git config --unset core.hooksPath`.
MSG
